---
// Corebalt wordmark: the network-node icon stands in for the "o".
// `size` is the font-size in px; the node scales to match the lettering.
interface Props {
  size?: number;
}
const { size = 23 } = Astro.props;
---
<span class="wordmark" style={`font-size:${size}px`} role="img" aria-label="Corebalt">
  <span aria-hidden="true">C</span>
  <svg class="wm-o" viewBox="30 27 40 40" aria-hidden="true">
    <line x1="50" y1="50" x2="50" y2="33" stroke="#fff" stroke-width="2.4" opacity=".5"/>
    <line x1="50" y1="50" x2="35.3" y2="58.5" stroke="#fff" stroke-width="2.4" opacity=".5"/>
    <line x1="50" y1="50" x2="64.7" y2="58.5" stroke="#fff" stroke-width="2.4" opacity=".5"/>
    <circle cx="50" cy="33" r="4.2" fill="#fff"/>
    <circle cx="35.3" cy="58.5" r="4.2" fill="#fff"/>
    <circle cx="64.7" cy="58.5" r="4.2" fill="#fff"/>
    <circle cx="50" cy="50" r="8.4" fill="#4D8BFF"/>
  </svg>
  <span aria-hidden="true">rebalt</span>
</span>
