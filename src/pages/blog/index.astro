---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<BaseLayout
  title="Blog — Corebalt"
  description="Notes from the Corebalt team on building software for Kenyan business — product deep-dives, engineering notes and the local context."
>
  <section class="page-head">
    <div class="wrap">
      <span class="eyebrow">Corebalt blog</span>
      <h1>Notes from the workshop.</h1>
      <p>Product deep-dives, engineering notes, and the local context behind the software we build.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="post-grid">
        {posts.map((post) => (
          <a class="post-card reveal" href={`/blog/${post.id}`}>
            <span class="date">{fmt(post.data.date)}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
