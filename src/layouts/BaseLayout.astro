---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Corebalt — Software that runs your whole business',
  description = 'Corebalt is a software studio building loan management (LenderFest), POS, ERP, CRM, data analytics and bespoke systems for businesses worldwide — with deep local-payments and compliance expertise rooted in Nairobi.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="scroll-progress" id="scrollBar"></div>
  <Header />
  <slot />
  <Footer />
  <ContactModal />

  <script>
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- sticky nav + scroll progress bar + parallax (one passive handler) ----
    const hdr = document.getElementById('hdr')!;
    const bar = document.getElementById('scrollBar')!;
    const parEls = [...document.querySelectorAll<HTMLElement>('[data-parallax]')];

    const onScroll = () => {
      hdr.classList.toggle('scrolled', window.scrollY > 30);

      const doc = document.documentElement;
      const max = doc.scrollHeight - doc.clientHeight;
      bar.style.width = (max > 0 ? (doc.scrollTop / max) * 100 : 0) + '%';

      if (!reduce) {
        const vh = window.innerHeight;
        for (const el of parEls) {
          const speed = parseFloat(el.dataset.parallax || '0');
          const r = el.getBoundingClientRect();
          const fromMid = r.top + r.height / 2 - vh / 2;
          el.style.setProperty('--par', (-fromMid * speed).toFixed(1) + 'px');
        }
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);

    // ---- mobile menu ----
    const menuBtn = document.getElementById('menuBtn')!;
    const navLinks = document.getElementById('navLinks')!;
    menuBtn.addEventListener('click', () => navLinks.classList.toggle('open'));
    navLinks.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => navLinks.classList.remove('open')));

    // ---- reveal on scroll, staggered per grid ----
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement;
          el.style.transitionDelay = (el.dataset.d || '0') + 'ms';
          el.classList.add('in');
          io.unobserve(el);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
      const sibs = el.parentElement
        ? [...el.parentElement.children].filter((c) => c.classList.contains('reveal'))
        : [el];
      el.dataset.d = String(sibs.indexOf(el) * 90);
      io.observe(el);
    });
  </script>
</body>
</html>
